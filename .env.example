# ============================================================================
# Echo Platform - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the required values
# For production deployment, use your actual API keys and secrets
# NEVER commit .env.local to version control!
# ============================================================================

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Echo Platform
NEXT_PUBLIC_APP_VERSION=1.0.0

# ============================================================================
# CONVEX BACKEND (REQUIRED)
# ============================================================================
# Get from: https://dashboard.convex.dev
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# ============================================================================
# AUTHENTICATION (CLERK) (REQUIRED)
# ============================================================================
# Get from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Clerk redirect URLs (update for production)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================================================================
# AI PROVIDERS (REQUIRED)
# ============================================================================
# OpenAI - Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
OPENAI_ORG_ID=org-xxxxxxxxxxxxx
OPENAI_MODEL_GPT4=gpt-4
OPENAI_MODEL_GPT35=gpt-3.5-turbo
OPENAI_MODEL_EMBEDDINGS=text-embedding-3-small

# Anthropic - Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# AI Configuration
AI_DEFAULT_PROVIDER=openai
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7
AI_TIMEOUT_MS=30000

# ============================================================================
# EMAIL SERVICE (RESEND) (REQUIRED)
# ============================================================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=notifications@yourdomain.com
RESEND_FROM_NAME=Echo Support
RESEND_REPLY_TO=support@yourdomain.com

# Email configuration
EMAIL_BATCH_SIZE=100
EMAIL_RATE_LIMIT=1000

# ============================================================================
# REDIS CACHE (OPTIONAL but recommended for production)
# ============================================================================
# Get from: Upstash, Redis Cloud, or self-hosted
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=
REDIS_TTL_DEFAULT=3600
REDIS_TTL_SESSION=1800
REDIS_TTL_CACHE=300

# ============================================================================
# AWS SERVICES (OPTIONAL)
# ============================================================================
# Get from: AWS IAM Console
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxx
AWS_REGION=us-east-1

# S3 Storage
AWS_S3_BUCKET=echo-platform-storage
AWS_S3_REGION=us-east-1

# CloudFront CDN
AWS_CLOUDFRONT_DOMAIN=d111111abcdef8.cloudfront.net
AWS_CLOUDFRONT_KEY_PAIR_ID=xxxxxxxxxxxxx
AWS_CLOUDFRONT_PRIVATE_KEY=xxxxxxxxxxxxx

# Secrets Manager
AWS_SECRETS_MANAGER_ENABLED=false
AWS_SECRETS_MANAGER_SECRET_NAME=echo/production/secrets

# ============================================================================
# MONITORING & OBSERVABILITY (SENTRY) (OPTIONAL)
# ============================================================================
# Get from: https://sentry.io/settings/
SENTRY_DSN=https://xxxxxxxxxxxxx@sentry.io/xxxxxxxxxxxxx
SENTRY_AUTH_TOKEN=xxxxxxxxxxxxx
SENTRY_ORG=your-organization
SENTRY_PROJECT=echo-platform

# Sentry Configuration
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE=1.0
SENTRY_UPLOAD_SOURCE_MAPS=true
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================================================
# SECURITY & RATE LIMITING
# ============================================================================
# Generate strong random keys for production!
ENCRYPTION_KEY=your-32-character-encryption-key-here
JWT_SECRET=your-jwt-secret-key-here
CSRF_SECRET=your-csrf-secret-key-here

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# IP Restrictions
IP_WHITELIST=
IP_BLACKLIST=

# Session Management
SESSION_TIMEOUT_MS=1800000
SESSION_MAX_AGE_MS=86400000
SESSION_SECURE=true
SESSION_HTTP_ONLY=true

# ============================================================================
# AUDIT SYSTEM
# ============================================================================
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=90
AUDIT_LOG_LEVEL=info
AUDIT_EXPORT_ENABLED=true

# ============================================================================
# WEBHOOK SYSTEM
# ============================================================================
WEBHOOK_ENABLED=true
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT_MS=30000
WEBHOOK_RATE_LIMIT=100
WEBHOOK_RETRY_DELAY_MS=1000
WEBHOOK_EXPONENTIAL_BACKOFF=true

# ============================================================================
# NOTIFICATION SYSTEM
# ============================================================================
NOTIFICATION_ENABLED=true
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_BATCH_SIZE=50
NOTIFICATION_QUEUE_ENABLED=true

# ============================================================================
# AI EVALUATION SYSTEM
# ============================================================================
EVALUATION_ENABLED=true
EVALUATION_AUTO_EVALUATE=true
EVALUATION_HALLUCINATION_THRESHOLD=0.3
EVALUATION_CONFIDENCE_THRESHOLD=0.7
EVALUATION_PROVIDER=openai

# ============================================================================
# WORKER QUEUES
# ============================================================================
WORKERS_ENABLED=true
WORKERS_CONCURRENCY=10
WORKERS_BATCH_SIZE=50
WORKERS_RETRY_DELAY_MS=5000
WORKERS_MAX_RETRIES=3

# Queue Configuration
QUEUE_EMAIL_ENABLED=true
QUEUE_EMBEDDINGS_ENABLED=true
QUEUE_SUMMARIES_ENABLED=true
QUEUE_WEBHOOKS_ENABLED=true
QUEUE_NOTIFICATIONS_ENABLED=true
QUEUE_ANALYTICS_ENABLED=true

# ============================================================================
# CRON JOBS
# ============================================================================
CRON_ENABLED=true
CRON_DAILY_ANALYTICS=0 2 * * *
CRON_CLEANUP_LOGS=0 3 * * *
CRON_BACKUP_DATA=0 4 * * *
CRON_PROCESS_QUEUE=*/5 * * * *
CRON_HEALTH_CHECK=*/1 * * * *

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_AI_MEMORY=true
FEATURE_SENTIMENT_ANALYSIS=true
FEATURE_UNIFIED_INBOX=true
FEATURE_AUTOMATION=true
FEATURE_CSAT=true
FEATURE_WEBHOOKS=true
FEATURE_AUDIT_LOGS=true
FEATURE_ANALYTICS=true
FEATURE_EVALUATION=true
FEATURE_COLLABORATION=true

# ============================================================================
# PERFORMANCE & OPTIMIZATION
# ============================================================================
# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL_DEFAULT=3600
CACHE_TTL_ANALYTICS=300
CACHE_TTL_USER_SESSION=1800

# Database Configuration
DB_CONNECTION_POOL_SIZE=10
DB_QUERY_TIMEOUT_MS=30000
DB_MAX_RETRIES=3

# API Configuration
API_TIMEOUT_MS=30000
API_MAX_RETRIES=3
API_RATE_LIMIT=1000

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_STDOUT=true
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7

# ============================================================================
# VERCEL DEPLOYMENT (Auto-populated by Vercel)
# ============================================================================
VERCEL_URL=
VERCEL_ENV=development
VERCEL_GIT_COMMIT_SHA=
VERCEL_GIT_COMMIT_MESSAGE=
VERCEL_GIT_COMMIT_AUTHOR_NAME=

# Vercel Configuration
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
# These should be disabled in production
NEXT_TELEMETRY_DISABLED=1
SKIP_ENV_VALIDATION=false
DEBUG_MODE=false
VERBOSE_LOGGING=false

# ============================================================================
# CUSTOM DOMAIN (Production)
# ============================================================================
NEXT_PUBLIC_DOMAIN=yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_CDN_URL=https://cdn.yourdomain.com

# ============================================================================
# THIRD-PARTY INTEGRATIONS (OPTIONAL)
# ============================================================================
# Slack Integration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_WEBHOOK_URL=

# Discord Integration
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_WEBHOOK_URL=

# Stripe Billing (if using)
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================================
# ANALYTICS & TRACKING (OPTIONAL)
# ============================================================================
# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mixpanel
NEXT_PUBLIC_MIXPANEL_TOKEN=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ============================================================================
# INTERNATIONALIZATION (OPTIONAL)
# ============================================================================
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,es,fr,de,ja

# ============================================================================
# NOTES FOR DEPLOYMENT
# ============================================================================
# 1. REQUIRED FOR DEPLOYMENT:
#    - CONVEX_DEPLOYMENT and NEXT_PUBLIC_CONVEX_URL
#    - CLERK keys
#    - At least one AI provider (OpenAI or Anthropic)
#    - RESEND_API_KEY
#
# 2. STRONGLY RECOMMENDED:
#    - REDIS_URL for caching
#    - SENTRY_DSN for error tracking
#    - Strong ENCRYPTION_KEY and JWT_SECRET
#
# 3. OPTIONAL BUT USEFUL:
#    - AWS services for storage and CDN
#    - Stripe for billing
#    - Google Analytics for tracking
#
# 4. SECURITY:
#    - Generate new secrets for production
#    - Never use test/development keys in production
#    - Rotate keys every 90 days
#    - Use AWS Secrets Manager in production
#
# 5. ENVIRONMENT-SPECIFIC:
#    - Development: .env.local
#    - Production: Set in Vercel/AWS/hosting platform
#    - CI/CD: Set in GitHub Secrets
# ============================================================================
