# ==============================================
# Echo - Environment Variables Template
# ==============================================
# Copy this file to .env.local and fill in the values

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Authentication (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Redis
REDIS_URL=redis://localhost:6379

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@example.com

# Observability (Sentry)
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE=1.0

# AWS (Optional - for backups/secrets manager)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Vercel
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=

# AI/LLM (for Memory System)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
